# ═══════════════════════════════════════════════════════════════════
# [NOMBRE_PROYECTO] - Variables de entorno
# Copiá a .env y completá los valores
# ═══════════════════════════════════════════════════════════════════

# --- Keystatic (GitHub mode en producción) ---
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=    # openssl rand -hex 32

# --- Site Config ---
SITE_URL=https://cluna.ar
BLOG_PATH=/blog

# --- Node ENV ---
NODE_ENV=development

# --- Pipeline de publicación (ver PIPELINE.md) ---

# Imagen de portada — Gemini (primario)
GEMINI_API_KEY=

# Imagen de portada — Kie.ai (fallback). KIE_API_BASE opcional: ajustar si el
# endpoint por defecto en scripts/cover-image.mjs no está vigente (verificar
# en docs.kie.ai antes del primer uso real, ver nota en PIPELINE.md §2).
KIE_API_KEY=
KIE_API_BASE=https://api.kie.ai

# Orden de providers (invertible sin tocar código)
IMAGE_PROVIDER_PRIMARY=gemini
IMAGE_PROVIDER_FALLBACK=kie

# LinkedIn (API REST /rest/posts). Token vence a los ~60 días — ver PIPELINE.md §4.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=          # urn:li:person:XXXXXXXX
LINKEDIN_API_VERSION=202506   # formato YYYYMM

# Telegram (canal/chat de Claudio + notificación de errores del pipeline)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
