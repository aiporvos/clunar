---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const password = form.get('password');
  const expected = import.meta.env.TIENDANUBE_PASSWORD;

  if (!expected) {
    error = 'Falta configurar TIENDANUBE_PASSWORD en el servidor.';
  } else if (password === expected) {
    Astro.session?.set('tiendanube_auth', true);
    return Astro.redirect('/tiendanube');
  } else {
    error = 'Contraseña incorrecta.';
  }
}
---

<BaseLayout title="Ingresar — cluna.ar/tiendanube" noIndex={true}>
  <main class="login-wrap">
    <form method="POST" class="login-card">
      <p class="eyebrow">cluna.ar/tiendanube</p>
      <h1>Ingresar</h1>
      {error && <p class="error">{error}</p>}
      <label class="field">
        <span>Contraseña</span>
        <input type="password" name="password" required autofocus autocomplete="current-password" />
      </label>
      <button type="submit">Entrar</button>
    </form>
  </main>
</BaseLayout>

<style>
  .login-wrap { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 2rem; font-family: 'Outfit', system-ui, sans-serif; }
  .login-card { background: hsl(var(--card)); border: 2px solid hsl(var(--foreground)); border-radius: 0.75rem; box-shadow: 4px 4px 0 hsl(var(--foreground)); padding: 2rem; width: 100%; max-width: 360px; display: flex; flex-direction: column; gap: 1rem; }
  .eyebrow { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: hsl(var(--muted-foreground)); margin: 0; }
  h1 { font-family: 'Paytone One', system-ui, sans-serif; font-size: 1.4rem; margin: 0 0 0.5rem; color: hsl(var(--foreground)); }
  .error { color: hsl(var(--crimson, 0 70% 45%)); font-size: 0.85rem; margin: 0; }
  .field { display: flex; flex-direction: column; gap: 0.3rem; font-size: 0.85rem; font-weight: 600; }
  .field input { font: inherit; padding: 0.6rem 0.7rem; border: 2px solid hsl(var(--foreground)); border-radius: 0.4rem; background: hsl(var(--background)); color: hsl(var(--foreground)); }
  button { font: inherit; font-weight: 700; padding: 0.7rem 1.5rem; border: 2px solid hsl(var(--foreground)); border-radius: 0.5rem; background: hsl(var(--primary)); color: hsl(var(--foreground)); box-shadow: 3px 3px 0 hsl(var(--foreground)); cursor: pointer; }
  button:hover { transform: translate(-1px, -1px); }
</style>
