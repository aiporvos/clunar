---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import schema from '../data/tiendanube-checklist-schema.json';
import { readFile } from 'node:fs/promises';
import { existsSync } from 'node:fs';
import path from 'node:path';

const JSON_PATH = path.resolve(process.cwd(), 'data', 'tiendanube-checklist-respuestas.json');
const answers: Record<string, any> = existsSync(JSON_PATH)
  ? JSON.parse(await readFile(JSON_PATH, 'utf-8'))
  : {};

const ESTADOS = ['Pendiente', 'En curso', 'Bloqueado', 'En validación', 'Aprobado'];
const val = (id: string) => answers[id] ?? '';
const checked = (id: string) => !!answers[id];
---

<BaseLayout title="cluna.ar/tiendanube" noIndex={true}>
  <main class="wrap">
    <header class="top">
      <p class="eyebrow">cluna.ar/tiendanube</p>
      <h1>{schema.titulo}</h1>
      <p class="sub">{schema.subtitulo}</p>
      <p class="desc">{schema.descripcion}</p>
      <p class="nota">{schema.nota}</p>
    </header>

    <form id="checklist-form">
      <section class="card">
        <h2>Datos generales</h2>
        <div class="grid-2">
          {schema.cabecera.map((c) => (
            <label class="field">
              <span>{c.label}</span>
              {c.tipo === 'date'
                ? <input type="date" name={c.id} value={val(c.id)} />
                : <input type="text" name={c.id} value={val(c.id)} placeholder={c.placeholder ?? ''} />
              }
            </label>
          ))}
        </div>
      </section>

      <section class="card">
        <h2>{schema.roles.titulo}</h2>
        {schema.roles.filas.map((r) => (
          <div class="role-row">
            <div class="role-info">
              <strong>{r.rol}</strong>
              <span>{r.responsabilidad}</span>
            </div>
            <label class="field">
              <span>Nombre</span>
              <input type="text" name={`${r.id}_nombre`} value={val(`${r.id}_nombre`)} />
            </label>
            <label class="field">
              <span>Canal</span>
              <input type="text" name={`${r.id}_canal`} value={val(`${r.id}_canal`)} />
            </label>
          </div>
        ))}
      </section>

      {schema.secciones.map((sec) => (
        <section class="card">
          <h2>{sec.titulo}</h2>
          {sec.intro && <p class="intro">{sec.intro}</p>}
          {sec.nota && <p class="nota-inline">⚠ {sec.nota}</p>}

          <div class="items">
            {sec.items.map((item, idx) => {
              const id = `${sec.id}-${idx}`;
              return (
                <div class="item-row">
                  <input type="checkbox" name={`${id}_ok`} checked={checked(`${id}_ok`)} class="ok-check" />
                  <div class="item-text">
                    <strong>{item.titulo}</strong>
                    <span class="detalle">{item.detalle}</span>
                    <span class="resp">{item.responsable}</span>
                  </div>
                  <select name={`${id}_estado`}>
                    {ESTADOS.map((e) => (
                      <option value={e} selected={val(`${id}_estado`) === e || (!val(`${id}_estado`) && e === 'Pendiente')}>{e}</option>
                    ))}
                  </select>
                  <input type="date" name={`${id}_fecha`} value={val(`${id}_fecha`)} class="fecha" />
                  <input type="text" name={`${id}_nota`} value={val(`${id}_nota`)} placeholder="Nota / evidencia" class="nota-item" />
                </div>
              );
            })}
          </div>

          {sec.salida && <p class="salida"><strong>Salida de fase:</strong> {sec.salida}</p>}
        </section>
      ))}

      <section class="card">
        <h2>{schema.aprobacionFinal.titulo}</h2>
        <div class="grid-2">
          {schema.aprobacionFinal.campos.map((c) => (
            <label class="field">
              <span>{c.label}</span>
              {c.tipo === 'date' ? (
                <input type="date" name={c.id} value={val(c.id)} />
              ) : c.tipo === 'select' ? (
                <select name={c.id}>
                  <option value="">— elegir —</option>
                  {c.opciones!.map((o) => <option value={o} selected={val(c.id) === o}>{o}</option>)}
                </select>
              ) : (
                <input type="text" name={c.id} value={val(c.id)} />
              )}
            </label>
          ))}
        </div>
      </section>

      <div class="save-bar">
        <button type="submit" id="save-btn">Guardar respuestas</button>
        <span id="save-status"></span>
      </div>
    </form>
  </main>
</BaseLayout>

<style>
  .wrap { max-width: 980px; margin: 0 auto; padding: 2rem 1.5rem 6rem; font-family: 'Outfit', system-ui, sans-serif; }
  .top { margin-bottom: 2rem; }
  .eyebrow { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: hsl(var(--muted-foreground)); margin-bottom: 0.5rem; }
  h1 { font-family: 'Paytone One', system-ui, sans-serif; font-size: 1.8rem; margin: 0 0 0.5rem; color: hsl(var(--foreground)); }
  .sub { font-weight: 600; margin: 0 0 0.5rem; }
  .desc { color: hsl(var(--muted-foreground)); margin: 0 0 0.5rem; }
  .nota { font-size: 0.8rem; color: hsl(var(--muted-foreground)); font-style: italic; }

  .card { background: hsl(var(--card)); border: 2px solid hsl(var(--foreground)); border-radius: 0.75rem; box-shadow: 4px 4px 0 hsl(var(--foreground)); padding: 1.5rem; margin-bottom: 1.5rem; }
  .card h2 { font-family: 'Paytone One', system-ui, sans-serif; font-size: 1.15rem; margin: 0 0 1rem; color: hsl(var(--foreground)); }
  .intro { color: hsl(var(--muted-foreground)); margin: -0.5rem 0 1rem; font-size: 0.9rem; }
  .nota-inline { background: hsl(var(--accent) / 0.1); border-left: 3px solid hsl(var(--accent)); padding: 0.5rem 0.75rem; font-size: 0.85rem; margin-bottom: 1rem; }

  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 640px) { .grid-2 { grid-template-columns: 1fr; } }

  .field { display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.85rem; font-weight: 600; }
  .field input, .field select { font: inherit; padding: 0.5rem 0.6rem; border: 2px solid hsl(var(--foreground)); border-radius: 0.4rem; background: hsl(var(--background)); color: hsl(var(--foreground)); }

  .role-row { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 1rem; align-items: end; padding: 0.75rem 0; border-top: 1px solid hsl(var(--border)); }
  .role-row:first-of-type { border-top: none; }
  .role-info { display: flex; flex-direction: column; gap: 0.15rem; }
  .role-info span { font-size: 0.8rem; color: hsl(var(--muted-foreground)); font-weight: 400; }
  @media (max-width: 640px) { .role-row { grid-template-columns: 1fr; } }

  .items { display: flex; flex-direction: column; gap: 0.6rem; }
  .item-row { display: grid; grid-template-columns: auto 2.2fr 1fr 1fr 1.3fr; gap: 0.6rem; align-items: start; padding: 0.6rem 0; border-top: 1px solid hsl(var(--border)); font-size: 0.85rem; }
  .item-row:first-of-type { border-top: none; }
  .ok-check { width: 1.2rem; height: 1.2rem; margin-top: 0.2rem; }
  .item-text { display: flex; flex-direction: column; gap: 0.1rem; }
  .item-text strong { font-size: 0.88rem; }
  .item-text .detalle { color: hsl(var(--muted-foreground)); font-size: 0.78rem; }
  .item-text .resp { align-self: flex-start; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; background: hsl(var(--primary)); color: hsl(var(--foreground)); padding: 0.1rem 0.5rem; border-radius: 999px; margin-top: 0.2rem; }
  .item-row select, .item-row input { font: inherit; font-size: 0.8rem; padding: 0.35rem 0.4rem; border: 2px solid hsl(var(--foreground)); border-radius: 0.4rem; background: hsl(var(--background)); color: hsl(var(--foreground)); }
  @media (max-width: 800px) {
    .item-row { grid-template-columns: 1fr; }
    .ok-check { justify-self: start; }
  }

  .salida { margin-top: 1rem; padding-top: 1rem; border-top: 2px dashed hsl(var(--border)); font-size: 0.85rem; }

  .save-bar { position: sticky; bottom: 0; display: flex; align-items: center; gap: 1rem; background: hsl(var(--background)); padding: 1rem 0; border-top: 2px solid hsl(var(--foreground)); }
  #save-btn { font: inherit; font-weight: 700; padding: 0.7rem 1.5rem; border: 2px solid hsl(var(--foreground)); border-radius: 0.5rem; background: hsl(var(--primary)); color: hsl(var(--foreground)); box-shadow: 3px 3px 0 hsl(var(--foreground)); cursor: pointer; }
  #save-btn:hover { transform: translate(-1px, -1px); }
  #save-status { font-size: 0.85rem; color: hsl(var(--muted-foreground)); }
</style>

<script>
  const form = document.getElementById('checklist-form') as HTMLFormElement;
  const status = document.getElementById('save-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data: Record<string, string | boolean> = {};
    const fd = new FormData(form);
    for (const [key, value] of fd.entries()) {
      data[key] = value as string;
    }
    // Los checkbox no marcados no aparecen en FormData: forzar false explícito.
    form.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((cb) => {
      data[cb.name] = cb.checked;
    });

    status.textContent = 'Guardando...';
    try {
      const res = await fetch('/api/tiendanube-checklist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      status.textContent = json.ok ? `✓ Guardado ${new Date().toLocaleTimeString('es-AR')}` : `✗ Error: ${json.error}`;
    } catch (err: any) {
      status.textContent = `✗ Error: ${err.message}`;
    }
  });
</script>
