---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import QuienSoy from '../components/sections/QuienSoy.astro';
import Tender from '../components/sections/Tender.astro';
import CasesCarousel from '../components/sections/CasesCarousel.astro';
import ComoTrabajo from '../components/sections/ComoTrabajo.astro';
import ParaQuien from '../components/sections/ParaQuien.astro';
import BlogPreview from '../components/sections/BlogPreview.astro';
import Contacto from '../components/sections/Contacto.astro';
import Marquee from '../components/sections/Marquee.astro';
---

<BaseLayout
  title="Claudio Luna | Automatización e IA para empresas — cluna.ar"
  description="Sistemas multi-agente, RAG especializado e integración de sistemas para empresas — con seguridad y gobernanza de datos. Adoptá IA sin perder el control de tu información."
>
  <Nav />
  <main>
    <Hero />
    <QuienSoy />
    <Marquee words={['AGENTES', 'RAG', 'ORQUESTACIÓN', 'GOBERNANZA', 'SELF-HOSTED', 'TRAZABILIDAD']} />
    <Tender />
    <CasesCarousel />
    <ComoTrabajo />
    <ParaQuien />
    <Marquee words={['n8n', 'MCP', 'QDRANT', 'SUPABASE', 'DOCKER', 'CLAUDE', 'LANGCHAIN']} speed={26} />
    <BlogPreview />
    <Contacto />
  </main>
  <Footer />
</BaseLayout>

<script>
  // Smooth scroll reveal
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.12 }
  );
  document.querySelectorAll('.reveal, .reveal-x').forEach(el => observer.observe(el));

  // Lenis smooth scroll
  import('lenis').then(({ default: Lenis }) => {
    const lenis = new Lenis({ lerp: 0.08, smoothWheel: true });
    function raf(time: number) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  }).catch(() => {});
</script>
