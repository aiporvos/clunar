---
interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Sitio web creado con HIVE',
  image,
  noIndex = false,
} = Astro.props;

const siteUrl = import.meta.env.SITE_URL || Astro.site?.toString() || '';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  {noIndex && <meta name="robots" content="noindex,nofollow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  {image && <meta property="og:image" content={image} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {image && <meta name="twitter:image" content={image} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700;900&family=Paytone+One&display=swap" rel="stylesheet" />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <slot />

  <!-- Barra de progreso de scroll + cursor de marca (ver BRAND.md §Motion) -->
  <div id="scroll-progress" aria-hidden="true"></div>
  <div id="cursor-ring" aria-hidden="true"></div>
  <div id="cursor-dot" aria-hidden="true"></div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  // Texto que se arma letra por letra (estilo daveholloway, en clave sticker)
  function splitInto(el: HTMLElement) {
    if (el.dataset.splitDone) return;
    const text = (el.textContent || '').trim();
    el.textContent = '';
    el.classList.add('split-ready');
    let i = 0;
    for (const ch of text) {
      const wrap = document.createElement('span');
      wrap.className = 'split-char-wrap';
      const c = document.createElement('span');
      c.className = 'split-char';
      c.textContent = ch === ' ' ? ' ' : ch;
      c.style.transitionDelay = (i * 0.03) + 's';
      wrap.appendChild(c);
      el.appendChild(wrap);
      i++;
    }
    el.dataset.splitDone = '1';
  }

  const splitEls = Array.from(document.querySelectorAll<HTMLElement>('[data-split]'));
  splitEls.forEach(splitInto);

  // Los del hero (data-split="load") se revelan al cargar; el resto, al hacer scroll
  requestAnimationFrame(() => {
    splitEls.filter(el => el.dataset.split === 'load').forEach((el, idx) => {
      setTimeout(() => el.classList.add('is-revealed'), 120 + idx * 140);
    });
  });

  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-revealed'); io.unobserve(e.target); } });
  }, { threshold: 0.35 });
  splitEls.filter(el => el.dataset.split !== 'load').forEach(el => io.observe(el));
</script>

<script>
  // ── Interacciones globales: progreso de scroll, cursor de marca, botones magnéticos ──
  const fine = matchMedia('(pointer: fine)').matches;
  const noMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Barra de progreso
  const bar = document.getElementById('scroll-progress');
  if (bar) {
    let rafP = 0;
    const setP = () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.setProperty('--scroll-p', String(max > 0 ? window.scrollY / max : 0));
      rafP = 0;
    };
    setP();
    window.addEventListener('scroll', () => { if (!rafP) rafP = requestAnimationFrame(setP); }, { passive: true });
  }

  // Cursor de marca: punto instantáneo + aro que lo persigue con inercia
  const dot = document.getElementById('cursor-dot');
  const ring = document.getElementById('cursor-ring');
  if (dot && ring && fine && !noMotion) {
    let mx = -100, my = -100, rx = -100, ry = -100;
    let running = false;

    function loop() {
      rx += (mx - rx) * 0.16;
      ry += (my - ry) * 0.16;
      ring!.style.transform = `translate(${rx}px, ${ry}px) translate(-50%,-50%) scale(var(--ring-s,1))`;
      if (Math.abs(mx - rx) + Math.abs(my - ry) > 0.2) {
        requestAnimationFrame(loop);
      } else {
        running = false; // el aro llegó: no quemamos frames al pedo
      }
    }

    window.addEventListener('mousemove', (e) => {
      mx = e.clientX; my = e.clientY;
      dot!.style.transform = `translate(${mx}px, ${my}px) translate(-50%,-50%)`;
      if (!running) { running = true; requestAnimationFrame(loop); }
    }, { passive: true });

    // El aro crece sobre elementos interactivos
    document.addEventListener('mouseover', (e) => {
      const t = (e.target as HTMLElement).closest('a, button, [data-magnetic], input, textarea, select, .tender-viewport');
      ring!.style.setProperty('--ring-s', t ? '1.7' : '1');
      ring!.classList.toggle('is-active', !!t);
    });
  }

  // Botones magnéticos: se acercan sutilmente al cursor
  if (fine && !noMotion) {
    document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach(el => {
      const strength = 0.28, max = 9;
      el.addEventListener('mousemove', (e) => {
        const r = el.getBoundingClientRect();
        const dx = Math.max(-max, Math.min(max, (e.clientX - (r.left + r.width / 2)) * strength));
        const dy = Math.max(-max, Math.min(max, (e.clientY - (r.top + r.height / 2)) * strength));
        el.style.transform = `translate(${dx.toFixed(1)}px, ${dy.toFixed(1)}px)`;
      });
      el.addEventListener('mouseleave', () => { el.style.transform = ''; });
    });
  }
</script>
