---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  excerpt: string;
  coverImage?: string;
  publishedAt: string;
  author: string;
  tags: string[];
  seoTitle?: string;
  seoDescription?: string;
}

const {
  title,
  excerpt,
  coverImage,
  publishedAt,
  author,
  tags,
  seoTitle,
  seoDescription,
} = Astro.props;

const siteUrl = import.meta.env.SITE_URL || '';
const fullImageUrl = coverImage ? `${siteUrl}${coverImage}` : undefined;

const formattedDate = new Date(publishedAt).toLocaleDateString('es-AR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={seoTitle || title}
  description={seoDescription || excerpt}
  image={fullImageUrl}
>
  <Nav />

  <!-- Widget flotante de compartir -->
  <aside class="fixed left-6 top-1/2 -translate-y-1/2 z-40 hidden xl:flex flex-col items-center gap-3">
    <!-- Progreso de lectura -->
    <div class="relative w-11 h-11">
      <svg class="w-11 h-11 -rotate-90" viewBox="0 0 44 44">
        <circle cx="22" cy="22" r="18" fill="none" stroke="#e5e5e0" stroke-width="3"/>
        <circle id="progress-ring" cx="22" cy="22" r="18" fill="none" stroke="#f97316" stroke-width="3"
                stroke-linecap="round" stroke-dasharray="113.1" stroke-dashoffset="113.1"/>
      </svg>
      <span id="progress-pct" class="absolute inset-0 flex items-center justify-center text-[10px] font-bold text-foreground">0%</span>
    </div>

    <!-- WhatsApp -->
    <a id="share-wa" href="#" target="_blank" rel="noopener"
       class="w-11 h-11 rounded-full bg-card border-brutal shadow-brutal-sm flex items-center justify-center hover:scale-110 transition-transform"
       title="Compartir en WhatsApp">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="#25D366">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.534 5.843L.057 23.547a.5.5 0 00.609.61l5.819-1.525A11.955 11.955 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.686-.523-5.21-1.433l-.374-.222-3.453.905.922-3.365-.244-.386A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
      </svg>
    </a>

    <!-- X / Twitter -->
    <a id="share-x" href="#" target="_blank" rel="noopener"
       class="w-11 h-11 rounded-full bg-card border-brutal shadow-brutal-sm flex items-center justify-center hover:scale-110 transition-transform"
       title="Compartir en X">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="#0a0a0a">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L2.25 2.25h6.883l4.258 5.632L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
      </svg>
    </a>

    <!-- LinkedIn -->
    <a id="share-li" href="#" target="_blank" rel="noopener"
       class="w-11 h-11 rounded-full bg-card border-brutal shadow-brutal-sm flex items-center justify-center hover:scale-110 transition-transform"
       title="Compartir en LinkedIn">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="#0A66C2">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>

    <!-- Facebook -->
    <a id="share-fb" href="#" target="_blank" rel="noopener"
       class="w-11 h-11 rounded-full bg-card border-brutal shadow-brutal-sm flex items-center justify-center hover:scale-110 transition-transform"
       title="Compartir en Facebook">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="#1877F2">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
    </a>

    <!-- Copiar link -->
    <button id="share-copy"
       class="w-11 h-11 rounded-full bg-card border-brutal shadow-brutal-sm flex items-center justify-center hover:scale-110 transition-transform relative"
       title="Copiar enlace">
      <svg class="w-4 h-4 text-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <rect x="9" y="9" width="13" height="13" rx="2"/>
        <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
      </svg>
      <span id="copy-tip" class="absolute left-14 bg-foreground text-white text-xs px-2 py-1 rounded whitespace-nowrap opacity-0 transition-opacity pointer-events-none">
        ¡Copiado!
      </span>
    </button>
  </aside>

  <main class="pt-24 pb-16 bg-background min-h-screen">
    <div class="container-site">
      <article class="max-w-3xl mx-auto">
        <!-- Header del post -->
        <header class="mb-10">
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
              {tags.map(tag => (
                <span class="pill-brutal text-xs px-3 py-1 bg-primary text-foreground font-bold">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-4 leading-tight">{title}</h1>
          <p class="text-xl text-muted-foreground mb-6 leading-relaxed">{excerpt}</p>

          <div class="flex items-center gap-4 text-sm text-muted-foreground">
            <span>Por {author}</span>
            <span>·</span>
            <time datetime={publishedAt}>{formattedDate}</time>
          </div>
        </header>

        <!-- Imagen de portada -->
        {coverImage && (
          <figure class="mb-10">
            <img
              src={coverImage}
              alt={title}
              class="w-full aspect-video object-cover rounded-2xl"
              loading="eager"
            />
          </figure>
        )}

        <!-- Contenido del post -->
        <div class="card-brutal p-8 md:p-12 prose prose-lg max-w-none
                    prose-headings:font-bold prose-headings:text-foreground
                    prose-a:text-accent prose-a:no-underline hover:prose-a:underline
                    prose-code:text-sm prose-p:text-muted-foreground prose-p:leading-relaxed">
          <slot />
        </div>

        <!-- Tags al final -->
        {tags.length > 0 && (
          <footer class="mt-8 pt-8 border-t border-border flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="pill-brutal px-3 py-1 text-sm text-foreground">
                #{tag}
              </span>
            ))}
          </footer>
        )}

        <div class="mt-8">
          <a href="/blog" class="inline-flex items-center gap-2 text-sm text-accent font-medium hover:underline">
            <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            Volver al blog
          </a>
        </div>
      </article>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const url  = encodeURIComponent(location.href);
  const text = encodeURIComponent(document.title);

  document.getElementById('share-wa')!.href  = `https://wa.me/?text=${text}%20${url}`;
  document.getElementById('share-x')!.href   = `https://x.com/intent/tweet?text=${text}&url=${url}`;
  document.getElementById('share-li')!.href  = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;
  document.getElementById('share-fb')!.href  = `https://www.facebook.com/sharer/sharer.php?u=${url}`;

  // Progreso de lectura
  const ring = document.getElementById('progress-ring') as SVGCircleElement;
  const pct  = document.getElementById('progress-pct')!;
  const circumference = 113.1;

  window.addEventListener('scroll', () => {
    const doc    = document.documentElement;
    const scroll = doc.scrollTop;
    const height = doc.scrollHeight - doc.clientHeight;
    const progress = height > 0 ? Math.round((scroll / height) * 100) : 0;

    ring.style.strokeDashoffset = String(circumference - (circumference * progress) / 100);
    pct.textContent = `${progress}%`;
  });

  // Copiar enlace
  document.getElementById('share-copy')!.addEventListener('click', async () => {
    await navigator.clipboard.writeText(location.href);
    const tip = document.getElementById('copy-tip')!;
    tip.style.opacity = '1';
    setTimeout(() => { tip.style.opacity = '0'; }, 2000);
  });
</script>
