---
<footer class="py-10 border-t" style="border-color:hsl(var(--border))">
  <div class="container mx-auto px-6">
    <div class="grid sm:grid-cols-3 gap-8 mb-8">
      <div>
        <div class="flex items-center gap-2 mb-3">
          <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28">
            <rect width="36" height="36" rx="8" fill="hsl(var(--primary))"/>
            <circle cx="13" cy="15" r="4" fill="hsl(var(--primary-foreground))"/>
            <circle cx="23" cy="15" r="4" fill="hsl(var(--primary-foreground))"/>
            <circle cx="13" cy="15" r="2" fill="hsl(var(--primary))"/>
            <circle cx="23" cy="15" r="2" fill="hsl(var(--primary))"/>
            <rect x="10" y="22" width="16" height="3" rx="1.5" fill="hsl(var(--primary-foreground))"/>
          </svg>
          <span class="font-display font-bold text-lg">AIporvos</span>
        </div>
        <p class="text-sm" style="color:hsl(var(--muted-foreground))">
          Agentes de IA para negocios reales. Automatizá sin código.
        </p>
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color:hsl(var(--muted-foreground))">Soluciones</p>
        <nav class="flex flex-col gap-2">
          {['Atención al Cliente','Vendedor Digital','Cobrador Amable','Consultor Legal','Bienes Raíces','Lector de Docs'].map(s => (
            <a href="#soluciones" class="text-sm transition-colors hover:opacity-100" style="color:hsl(var(--muted-foreground))">{s}</a>
          ))}
        </nav>
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color:hsl(var(--muted-foreground))">Contacto</p>
        <a href="https://wa.me/542604844952" target="_blank" rel="noopener noreferrer"
           class="text-sm flex items-center gap-2 mb-2 transition-colors hover:opacity-100"
           style="color:hsl(var(--muted-foreground))">
          <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
