        <a href="#contacto" class="text-sm transition-colors hover:opacity-100" style="color:hsl(var(--primary))">
          Demo personalizada →
        </a>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-6 border-t" style="border-color:hsl(var(--border))">
