---
interface Props {
  title: string;
  excerpt: string;
  slug: string;
  coverImage?: string;
  publishedAt: string;
  tags?: string[];
}

const { title, excerpt, slug, coverImage, publishedAt, tags = [] } = Astro.props;

const formattedDate = new Date(publishedAt).toLocaleDateString('es-AR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="card-brutal group flex flex-col h-full overflow-hidden" style="background:hsl(var(--card))">
  {coverImage && (
    <a href={`/blog/${slug}`} class="img-fx block" style="border-bottom:2px solid hsl(var(--foreground))">
      <img
        src={coverImage}
        alt={title}
        class="img-glitch w-full aspect-video object-cover"
        loading="lazy"
      />
    </a>
  )}

  <div class="flex flex-col flex-1 p-6">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-3">
        {tags.slice(0, 2).map(tag => (
          <span class="pill-brutal px-2.5 py-0.5 text-xs" style="background:hsl(var(--primary));color:hsl(var(--foreground))">#{tag}</span>
        ))}
      </div>
    )}

    <h2 class="font-display text-lg mb-2 leading-snug">
      <a href={`/blog/${slug}`} class="transition-colors hover:opacity-70" style="color:hsl(var(--foreground))">
        {title}
      </a>
    </h2>

    <p class="text-sm flex-1 line-clamp-3" style="color:hsl(var(--muted-foreground))">{excerpt}</p>

    <div class="flex items-center justify-between mt-4 pt-4" style="border-top:2px solid hsl(var(--foreground))">
      <time class="text-xs" style="color:hsl(var(--muted-foreground))" datetime={publishedAt}>
        {formattedDate}
      </time>
      <a
        href={`/blog/${slug}`}
        class="text-sm font-bold hover:underline"
        style="color:hsl(var(--foreground))"
      >
        Leer más →
      </a>
    </div>
  </div>
</article>
