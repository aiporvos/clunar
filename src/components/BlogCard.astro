---
interface Props {
  title: string;
  excerpt: string;
  slug: string;
  coverImage?: string;
  publishedAt: string;
  tags?: string[];
}

const { title, excerpt, slug, coverImage, publishedAt, tags = [] } = Astro.props;

const formattedDate = new Date(publishedAt).toLocaleDateString('es-AR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group flex flex-col h-full bg-white rounded-xl border border-gray-100
                hover:border-[var(--color-primary)] hover:shadow-md transition-all duration-200">
  {coverImage && (
    <a href={`/blog/${slug}`} class="block overflow-hidden rounded-t-xl">
      <img
        src={coverImage}
        alt={title}
        class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </a>
  )}

  <div class="flex flex-col flex-1 p-6">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1 mb-3">
        {tags.slice(0, 2).map(tag => (
          <span class="text-xs text-[var(--color-primary)]">#{tag}</span>
        ))}
      </div>
    )}

    <h2 class="text-lg font-bold mb-2 leading-snug">
      <a href={`/blog/${slug}`} class="hover:text-[var(--color-primary)] transition-colors">
        {title}
      </a>
    </h2>

    <p class="text-gray-600 text-sm flex-1 line-clamp-3">{excerpt}</p>

    <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
      <time class="text-xs text-gray-400" datetime={publishedAt}>
        {formattedDate}
      </time>
      <a
        href={`/blog/${slug}`}
        class="text-sm font-medium text-[var(--color-primary)] hover:underline"
      >
        Leer más →
      </a>
    </div>
  </div>
</article>
