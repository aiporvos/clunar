---
interface Props {
  title: string;
  subtitle: string;
  cta?: {
    label: string;
    href: string;
  };
  secondaryCta?: {
    label: string;
    href: string;
  };
}

const { title, subtitle, cta, secondaryCta } = Astro.props;
---

<section class="py-20 md:py-32">
  <div class="container-content text-center">
    <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
      {title}
    </h1>
    <p class="text-xl md:text-2xl text-gray-600 max-w-2xl mx-auto mb-10">
      {subtitle}
    </p>

    {(cta || secondaryCta) && (
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        {cta && (
          <a href={cta.href} class="btn-primary">
            {cta.label}
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn-secondary">
            {secondaryCta.label}
          </a>
        )}
      </div>
    )}
  </div>
</section>
