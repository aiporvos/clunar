---
// Header del sitio — personalizar logo y nav en keystatic (siteConfig singleton)
---

<header class="border-b border-gray-100 bg-white/95 backdrop-blur-sm sticky top-0 z-50">
  <div class="container-content">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="font-bold text-xl text-[var(--color-primary)]">
        HIVE Site
      </a>

      <!-- Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/" class="text-gray-600 hover:text-gray-900 transition-colors">Inicio</a>
        <a href="/blog" class="text-gray-600 hover:text-gray-900 transition-colors">Blog</a>
        <a href="/about" class="text-gray-600 hover:text-gray-900 transition-colors">Sobre mí</a>
        <a href="/#contacto" class="btn-primary text-sm py-2">Contacto</a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="menu-btn"
        class="md:hidden p-2 text-gray-600 hover:text-gray-900"
        aria-label="Abrir menú"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="md:hidden hidden pb-4">
      <div class="flex flex-col gap-2">
        <a href="/" class="py-2 text-gray-600 hover:text-gray-900">Inicio</a>
        <a href="/blog" class="py-2 text-gray-600 hover:text-gray-900">Blog</a>
        <a href="/about" class="py-2 text-gray-600 hover:text-gray-900">Sobre mí</a>
        <a href="/#contacto" class="btn-primary text-sm py-2 text-center mt-2">Contacto</a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
