---
const servicios = [
  {
    code: 'AUTO', num: '01·26',
    name: 'Automatizaciones',
    desc: 'Flujos que hacen el trabajo repetitivo por vos, sin código.',
    top: ['n8n', 'WhatsApp', 'Integraciones', 'Flujos'],
    bot: ['Facturación', 'Reportes', 'Emails', 'CRM'],
    color: 'hsl(var(--primary))', fg: 'hsl(var(--foreground))',
  },
  {
    code: 'AGENTE', num: '02·26',
    name: 'Agentes de IA',
    desc: 'Asistentes que atienden, venden, cobran y leen documentos 24/7.',
    top: ['Ventas', 'Atención', 'Cobranzas', 'Documentos'],
    bot: ['RAG', 'Memoria', 'Multicanal', '24/7'],
    color: 'var(--blue)', fg: '#fff',
  },
  {
    code: 'CLASE', num: '03·26',
    name: 'Capacitaciones',
    desc: 'Formaciones de IA aplicada para equipos y líderes, de cero.',
    top: ['n8n', 'IA aplicada', 'Prompting', 'Liderazgo'],
    bot: ['Cursos', 'Talleres', 'In-company', 'Mentorías'],
    color: 'hsl(var(--success))', fg: '#fff',
  },
  {
    code: 'WEB', num: '04·26',
    name: 'Web & Ecommerce',
    desc: 'Sitios y tiendas pensados para convertir, no solo para verse lindos.',
    top: ['Astro', 'TiendaNube', 'Landing', 'SEO'],
    bot: ['Diseño', 'Conversión', 'Performance', 'FTP'],
    color: 'var(--pink)', fg: 'hsl(var(--foreground))',
  },
  {
    code: 'CONSUL', num: '05·26',
    name: 'Consultoría IA',
    desc: 'Te ayudo a decidir qué automatizar, con qué stack y a qué costo.',
    top: ['Diagnóstico', 'Arquitectura', 'Modelos', 'Roadmap'],
    bot: ['Estrategia', 'Costos', 'Stack', 'Orquestación'],
    color: 'var(--purple)', fg: '#fff',
  },
  {
    code: 'DOCS', num: '06·26',
    name: 'Datos & Documentos',
    desc: 'Leo contratos, facturas y papeles y los convierto en datos útiles.',
    top: ['OCR', 'Extracción', 'Clasificación', 'Análisis'],
    bot: ['PDF/Excel', 'Dashboards', 'Búsqueda', 'Export'],
    color: 'hsl(var(--accent))', fg: '#fff',
  },
];
---

<section id="soluciones" class="py-24 lg:py-32 overflow-hidden">
  <div class="container mx-auto px-6">

    <div class="reveal">
      <div class="flex items-center gap-4 mb-8">
        <span class="w-12 h-px" style="background:hsl(var(--foreground))"></span>
        <span class="text-sm uppercase tracking-widest font-medium">Servicios</span>
      </div>
      <div class="max-w-2xl mb-16">
        <h2 class="font-display text-display-md font-bold glow-text mb-6">En qué puedo ayudarte.</h2>
        <p class="text-lg" style="color:hsl(var(--muted-foreground))">Desde automatizaciones y agentes de IA hasta capacitaciones y desarrollo. Elegí uno, varios, o armamos algo a medida.</p>
      </div>
    </div>

    <!-- TENDER RAIL -->
    <div class="tender-section reveal">
      <div class="tender-rail">
        <div class="tender-rail-line"></div>
        {servicios.map((_, i) => (
          <div class="tender-clip" style={`left: calc(${(i / (servicios.length - 1)) * 100}%)`}></div>
        ))}
      </div>

      <div class="tender-track" id="tender-track">
        {servicios.map((s) => (
          <div class="tender-tag">
            <!-- Etiqueta colgante sobre el riel -->
            <div class="tender-pin" style={`background:${s.color};color:${s.fg}`}>
              <span class="tender-pin-code">{s.code}</span>
              <span class="tender-pin-num">{s.num}</span>
            </div>
            <div class="tender-string"></div>

            <div class="tender-card">
              <!-- Panel negro con palabra grande -->
              <div class="tender-word-panel">
                <span class="tender-word" style={`color:${s.color}`}>{s.code}</span>
              </div>

              <!-- Banda de servicio -->
              <div class="tender-band" style={`background:${s.color};color:${s.fg}`}>
                <span class="tender-service-label">SERVICIO</span>
                <span class="tender-service-name">{s.name}</span>
              </div>

              <!-- Descripción -->
              <p class="tender-description">{s.desc}</p>

              <!-- Regla de markers -->
              <div class="tender-ruler">
                <div class="tender-ruler-grid">
                  {s.top.map((t, i) => (
                    <div class="tender-col">
                      <span class="tender-col-top">{t}</span>
                      <span class="tender-tri">▼</span>
                      <span class="tender-col-bot">{s.bot[i]}</span>
                    </div>
                  ))}
                </div>
              </div>

              <a href="#contacto" class="tender-cta" style={`background:${s.color};color:${s.fg}`}>
                Lo quiero →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .tender-section { position: relative; padding-top: 40px; }

  /* Riel */
  .tender-rail { position: relative; height: 20px; margin-bottom: 0; }
  .tender-rail-line {
    position: absolute; top: 50%; left: 0; right: 0; height: 3px;
    background: hsl(var(--foreground)); transform: translateY(-50%); border-radius: 2px;
  }
  .tender-clip {
    position: absolute; top: 50%; transform: translate(-50%, -50%);
    width: 12px; height: 12px; border-radius: 50%;
    background: hsl(var(--foreground)); border: 2px solid hsl(var(--background));
  }

  /* Track horizontal */
  .tender-track {
    display: flex; gap: 26px; overflow-x: auto;
    scroll-snap-type: x mandatory; scrollbar-width: none;
    padding: 18px 8px 32px; cursor: grab;
  }
  .tender-track::-webkit-scrollbar { display: none; }
  .tender-track:active { cursor: grabbing; }

  /* Etiqueta colgante */
  .tender-tag {
    flex-shrink: 0; scroll-snap-align: start;
    display: flex; flex-direction: column; align-items: center;
    width: 280px;
  }
  .tender-pin {
    display: flex; flex-direction: column; align-items: center; line-height: 1;
    padding: 7px 16px; border-radius: 8px;
    border: 2.5px solid hsl(var(--foreground));
    box-shadow: 3px 3px 0 hsl(var(--foreground));
    margin-bottom: -2px; z-index: 2;
  }
  .tender-pin-code { font-family: 'Paytone One', sans-serif; font-size: 0.85rem; letter-spacing: 0.08em; }
  .tender-pin-num { font-family: monospace; font-size: 0.58rem; opacity: 0.85; margin-top: 2px; }
  .tender-string { width: 3px; height: 26px; background: hsl(var(--foreground)); }

  /* Tarjeta */
  .tender-card {
    width: 100%; border-radius: 14px;
    border: 2.5px solid hsl(var(--foreground));
    background: hsl(var(--card)); overflow: hidden;
    box-shadow: 5px 5px 0 hsl(var(--foreground));
    transform-origin: top center;
    transition: transform 0.35s cubic-bezier(.22,.68,0,1.2), box-shadow 0.3s ease;
  }
  .tender-tag:hover .tender-card {
    transform: rotate(-1.2deg) translateY(4px);
    box-shadow: 8px 8px 0 hsl(var(--foreground));
  }

  /* Panel negro con palabra grande */
  .tender-word-panel {
    background: var(--coal);
    height: 150px; display: flex; align-items: center; justify-content: center;
    overflow: hidden; border-bottom: 2.5px solid hsl(var(--foreground));
  }
  .tender-word {
    font-family: 'Paytone One', sans-serif;
    font-size: 4.2rem; line-height: 0.9; white-space: nowrap;
    text-transform: uppercase; letter-spacing: -0.02em;
    text-shadow: 0 0 30px currentColor;
  }

  /* Banda servicio */
  .tender-band { padding: 14px 16px; display: flex; flex-direction: column; gap: 2px; }
  .tender-service-label { font-size: 0.6rem; letter-spacing: 0.2em; opacity: 0.85; font-weight: 700; }
  .tender-service-name { font-family: 'Paytone One', sans-serif; font-size: 1.25rem; }

  .tender-description {
    padding: 12px 16px; font-size: 0.85rem; line-height: 1.5;
    color: hsl(var(--muted-foreground));
    border-bottom: 2px solid hsl(var(--foreground));
  }

  /* Regla de markers */
  .tender-ruler { position: relative; padding: 16px; border-bottom: 2px solid hsl(var(--foreground)); }
  .tender-ruler::before {
    content: ""; position: absolute; left: 16px; right: 16px; top: 50%;
    transform: translateY(-50%); height: 2px; background: hsl(var(--foreground));
  }
  .tender-ruler-grid { position: relative; display: grid; grid-template-columns: repeat(4, 1fr); }
  .tender-col {
    display: grid; grid-template-rows: 1fr auto 1fr; align-items: center; justify-items: center;
    gap: 6px; text-align: center; min-height: 66px;
  }
  .tender-col-top, .tender-col-bot {
    font-size: 0.6rem; font-weight: 700; line-height: 1.15; color: hsl(var(--foreground));
    text-transform: uppercase; letter-spacing: 0.02em;
  }
  .tender-col-bot { color: hsl(var(--muted-foreground)); }
  .tender-tri { font-size: 0.6rem; color: hsl(var(--foreground)); line-height: 1; }

  /* CTA */
  .tender-cta {
    display: block; text-align: center; padding: 13px 16px;
    font-family: 'Paytone One', sans-serif; font-size: 0.85rem;
    text-transform: uppercase; letter-spacing: 0.06em; text-decoration: none;
    transition: filter 0.2s;
  }
  .tender-cta:hover { filter: brightness(0.94); }

  @media (max-width: 640px) {
    .tender-tag { width: 250px; }
    .tender-word { font-size: 3.4rem; }
  }
</style>

<script>
  const track = document.getElementById('tender-track');
  let isDown = false, startX = 0, scrollLeft = 0;
  track?.addEventListener('mousedown', e => { isDown = true; startX = e.pageX - (track.offsetLeft || 0); scrollLeft = track.scrollLeft; });
  track?.addEventListener('mouseleave', () => { isDown = false; });
  track?.addEventListener('mouseup', () => { isDown = false; });
  track?.addEventListener('mousemove', e => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - (track.offsetLeft || 0);
    track.scrollLeft = scrollLeft - (x - startX) * 1.5;
  });
</script>
