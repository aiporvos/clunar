---
const servicios = [
  {
    code: 'AGENTES', num: '01·26',
    name: 'Sistemas Multi-agente',
    desc: 'Agentes orquestados sobre tus procesos: derivan, registran y escalan a un humano cuando corresponde.',
    top: ['Ventas', 'Briefing', 'Turnos', 'Competencia'],
    bot: ['Orquestación', 'Memoria', 'Trazabilidad', 'Escalado'],
    color: 'hsl(var(--primary))', fg: 'hsl(var(--foreground))',
  },
  {
    code: 'RAG', num: '02·26',
    name: 'RAG Especializado',
    desc: 'Tu conocimiento consultable con precisión: responde con tus documentos, no con lo que inventa el modelo.',
    top: ['Legal', 'Clínico', 'Técnico', 'Catálogos'],
    bot: ['Qdrant', 'Supabase', 'Citas', 'Ingesta'],
    color: 'var(--blue)', fg: '#fff',
  },
  {
    code: 'INTEG', num: '03·26',
    name: 'Integración & Orquestación',
    desc: 'Conecto los sistemas que ya tenés (ERP, CRM, facturación, e-commerce) para que dejen de necesitar copy-paste humano.',
    top: ['ERP', 'CRM', 'Facturación', 'E-commerce'],
    bot: ['n8n', 'MCP', 'WhatsApp Meta', 'YCloud'],
    color: 'hsl(var(--accent))', fg: '#fff',
  },
  {
    code: 'DATA', num: '04·26',
    name: 'Seguridad & Gobernanza',
    desc: 'Adoptá IA sin perder el control: infraestructura propia, permisos por agente y continuidad si cambia el proveedor.',
    top: ['Self-hosted', 'Permisos', 'Trazabilidad', 'Backups'],
    bot: ['VPS propio', 'Docker', 'Auditoría', 'Continuidad'],
    color: 'var(--crimson)', fg: '#fff',
  },
  {
    code: 'CONSUL', num: '05·26',
    name: 'Consultoría IA',
    desc: 'Qué automatizar, con qué stack y a qué costo, con números reales. A veces la respuesta es no.',
    top: ['Diagnóstico', 'Arquitectura', 'Modelos', 'Roadmap'],
    bot: ['Estrategia', 'Costos', 'Stack', 'Gobernanza'],
    color: 'var(--purple)', fg: '#fff',
  },
  {
    code: 'CLASE', num: '06·26',
    name: 'Formación de Equipos',
    desc: 'Capacitación de IA aplicada para equipos y líderes: de la herramienta al criterio.',
    top: ['IA aplicada', 'n8n', 'Prompting', 'Liderazgo'],
    bot: ['Talleres', 'In-company', 'Mentorías', 'Práctica'],
    color: 'hsl(var(--success))', fg: '#fff',
  },
];
---

<section id="soluciones" class="py-16 sm:py-24 lg:py-32 overflow-hidden">
  <div class="container mx-auto px-6">

    <div class="reveal">
      <div class="flex items-center gap-4 mb-8">
        <span class="w-12 h-px" style="background:hsl(var(--foreground))"></span>
        <span class="text-sm uppercase tracking-widest font-medium">Servicios</span>
      </div>
      <div class="max-w-2xl mb-16">
        <h2 class="font-display text-display-md font-bold glow-text mb-6">Si querés que trabajemos juntos.</h2>
        <p class="text-lg" style="color:hsl(var(--muted-foreground))">Sistemas multi-agente, RAG, integración y gobernanza de datos: de un servicio puntual a la arquitectura completa. Contame en qué estás trabajando y vemos si puedo sumarte valor.</p>
      </div>
    </div>

    <!-- TENDER RAIL -->
    <div class="tender-section reveal">
      <div class="tender-viewport">
        <div class="tender-track" id="tender-track">
        {[...servicios, ...servicios, ...servicios].map((s, idx) => (
          <div class="tender-tag" aria-hidden={idx >= servicios.length ? 'true' : undefined}>
            <!-- Cable: tramo IZQ por detrás de la etiqueta (entra al ojal) -->
            <span class="tender-wire wire-back"></span>

            <!-- Etiqueta con ojal (el ojal real se dibuja en .tender-grommet, encima) -->
            <div class="tender-pin" style={`background:${s.color};color:${s.fg}`}>
              <span class="tender-pin-code">{s.code}</span>
              <span class="tender-eyelet"></span>
              <span class="tender-pin-num">{s.num}</span>
            </div>

            <!-- Cable: tramo DER por delante (sale del ojal) + grommet que tapa el centro -->
            <span class="tender-wire wire-front"></span>
            <span class="tender-grommet"></span>

            <div class="tender-card">
              <!-- Panel negro con palabra grande -->
              <div class="tender-word-panel">
                <span class="tender-word" style={`color:${s.color}`}>{s.code}</span>
              </div>

              <!-- Banda de servicio -->
              <div class="tender-band" style={`background:${s.color};color:${s.fg}`}>
                <span class="tender-service-label">SERVICIO</span>
                <span class="tender-service-name">{s.name}</span>
              </div>

              <!-- Descripción -->
              <p class="tender-description">{s.desc}</p>

              <!-- Regla de markers -->
              <div class="tender-ruler">
                <div class="tender-ruler-grid">
                  {s.top.map((t, i) => (
                    <div class="tender-col">
                      <span class="tender-col-top">{t}</span>
                      <span class="tender-tri">▼</span>
                      <span class="tender-col-bot">{s.bot[i]}</span>
                    </div>
                  ))}
                </div>
              </div>

              <a href="#contacto" class="tender-cta" style={`background:${s.color};color:${s.fg}`}>
                Me interesa →
              </a>
            </div>
          </div>
        ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .tender-section { position: relative; padding-top: 20px; }

  /* Viewport a ancho completo, scrolleable con la manito */
  .tender-viewport {
    position: relative; overflow-x: auto; overflow-y: hidden;
    padding: 14px 0 32px;
    scrollbar-width: none;
    user-select: none; -webkit-user-select: none;
    cursor: grab;
  }
  .tender-viewport::-webkit-scrollbar { display: none; }
  .tender-viewport.is-dragging { cursor: grabbing; }

  /* Track: corre solo (auto-scroll por JS) y se puede arrastrar */
  .tender-track {
    display: flex; width: max-content;
  }

  /* Cable en dos capas por etiqueta: atraviesa físicamente el ojal.
     --wire-top (centro del ojal) lo pone el JS. */
  .tender-wire {
    position: absolute; top: var(--wire-top, 42px); height: 9px;
    transform: translateY(-50%); pointer-events: none;
    background: linear-gradient(to bottom, #565049 0%, #3a352f 45%, #211d19 100%);
    border-radius: 5px;
    box-shadow: inset 0 1.5px 0 hsl(0 0% 100% / 0.2), 0 1px 2px hsl(0 0% 0% / 0.35);
  }
  /* tramo continuo POR DETRÁS de la etiqueta (de lado a lado, sin empalme visible) */
  .wire-back  { left: -54px; right: -54px; z-index: 1; }
  /* tramo derecho POR DELANTE (sale del ojal) → sensación de atravesar */
  .wire-front { left: 50%; width: calc(50% + 54px); z-index: 4; }

  /* Ojal real (grommet) encima de todo: tapa parcialmente el cable → profundidad */
  .tender-grommet {
    position: absolute; left: 50%; top: var(--wire-top, 42px);
    transform: translate(-50%, -50%);
    width: 26px; height: 26px; border-radius: 50%; z-index: 5; pointer-events: none;
    background: radial-gradient(circle at 50% 38%, #2a2620 0%, #17140f 60%, #0b0908 100%);
    border: 2.5px solid hsl(var(--foreground));
    box-shadow: inset 0 2px 4px hsl(0 0% 0% / 0.8), 0 1px 0 hsl(0 0% 100% / 0.12);
  }

  /* Etiqueta */
  .tender-tag {
    position: relative;
    flex-shrink: 0;
    display: flex; flex-direction: column; align-items: center;
    width: 380px; margin-right: 56px; /* margin en vez de gap → loop sin corte */
  }
  /* Etiqueta cuadrada estilo "DEV": código arriba, agujero al centro, número abajo */
  .tender-pin {
    position: relative; z-index: 3;
    width: 84px; height: 84px;
    display: flex; flex-direction: column; align-items: center; justify-content: space-between;
    padding: 10px 6px; border-radius: 14px; line-height: 1;
    border: 2.5px solid hsl(var(--foreground));
    box-shadow: 3px 3px 0 hsl(var(--foreground));
  }
  .tender-pin-code { font-family: 'Paytone One', sans-serif; font-size: 0.8rem; letter-spacing: 0.06em; }
  .tender-pin-num { font-family: monospace; font-size: 0.55rem; opacity: 0.9; letter-spacing: 0.02em; }
  /* Espaciador del ojal (mantiene el layout del pin); el ojal visible es .tender-grommet */
  .tender-eyelet {
    width: 26px; height: 26px; visibility: hidden;
  }

  /* Tarjeta (cuelga del cable, por debajo del pin) */
  .tender-card {
    margin-top: -30px; position: relative; z-index: 2;
    width: 100%; border-radius: 14px;
    border: 2.5px solid hsl(var(--foreground));
    background: hsl(var(--card)); overflow: hidden;
    box-shadow: 5px 5px 0 hsl(var(--foreground));
    /* Pivota desde el ojal (arriba) para balancearse como colgada del cable */
    transform-origin: top center;
    transform: rotate(var(--sway, 0deg));
    transition: box-shadow 0.3s ease;
    will-change: transform;
  }
  .tender-tag:hover .tender-card {
    box-shadow: 7px 9px 0 hsl(var(--foreground));
  }

  /* Panel negro con palabra grande */
  .tender-word-panel {
    background: var(--coal);
    height: 150px; display: flex; align-items: center; justify-content: center;
    overflow: hidden; border-bottom: 2.5px solid hsl(var(--foreground));
  }
  .tender-word {
    font-family: 'Paytone One', sans-serif;
    font-size: 4.2rem; line-height: 0.9; white-space: nowrap;
    text-transform: uppercase; letter-spacing: -0.02em;
    text-shadow: 0 0 10px hsl(0 0% 0% / 0.25);
  }

  /* Banda servicio */
  .tender-band { padding: 14px 16px; display: flex; flex-direction: column; gap: 2px; }
  .tender-service-label { font-size: 0.6rem; letter-spacing: 0.2em; opacity: 0.85; font-weight: 700; }
  .tender-service-name { font-family: 'Paytone One', sans-serif; font-size: 1.25rem; }

  .tender-description {
    padding: 12px 16px; font-size: 0.85rem; line-height: 1.5;
    color: hsl(var(--muted-foreground));
    border-bottom: 2px solid hsl(var(--foreground));
  }

  /* Regla de markers */
  .tender-ruler { position: relative; padding: 16px; border-bottom: 2px solid hsl(var(--foreground)); }
  .tender-ruler::before {
    content: ""; position: absolute; left: 16px; right: 16px; top: 50%;
    transform: translateY(-50%); height: 2px; background: hsl(var(--foreground));
  }
  .tender-ruler-grid { position: relative; display: grid; grid-template-columns: repeat(4, 1fr); }
  .tender-col {
    display: grid; grid-template-rows: 1fr auto 1fr; align-items: center; justify-items: center;
    gap: 6px; text-align: center; min-height: 66px;
  }
  .tender-col-top, .tender-col-bot {
    font-size: 0.6rem; font-weight: 700; line-height: 1.15; color: hsl(var(--foreground));
    text-transform: uppercase; letter-spacing: 0.02em;
  }
  .tender-col-bot { color: hsl(var(--muted-foreground)); }
  .tender-tri { font-size: 0.6rem; color: hsl(var(--foreground)); line-height: 1; }

  /* CTA */
  .tender-cta {
    display: block; text-align: center; padding: 13px 16px;
    font-family: 'Paytone One', sans-serif; font-size: 0.85rem;
    text-transform: uppercase; letter-spacing: 0.06em; text-decoration: none;
    transition: filter 0.2s;
  }
  .tender-cta:hover { filter: brightness(0.94); }

  @media (max-width: 640px) {
    .tender-tag { width: 300px; margin-right: 36px; }
    .tender-word { font-size: 2.7rem; }
    .tender-word-panel { height: 110px; }
    .tender-viewport { -webkit-overflow-scrolling: touch; }
  }
</style>

<script>
  const track = document.getElementById('tender-track');
  const viewport = track?.parentElement as HTMLElement | null;

  // Alinear el cable y el grommet con el centro exacto del ojal (por tarjeta, mismo valor)
  function placeWire() {
    if (!track) return;
    const eye = track.querySelector('.tender-eyelet') as HTMLElement | null;
    const tag = eye?.closest('.tender-tag') as HTMLElement | null;
    if (!eye || !tag) return;
    const eRect = eye.getBoundingClientRect();
    const tRect = tag.getBoundingClientRect();
    const top = eRect.top - tRect.top + eRect.height / 2;
    track.style.setProperty('--wire-top', top + 'px');
  }
  placeWire();
  window.addEventListener('load', placeWire);
  window.addEventListener('resize', placeWire);

  // Auto-scroll continuo + arrastre (izq/der) con loop infinito (3 copias)
  if (viewport && track) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // En táctil no hay auto-scroll: el usuario navega con el dedo (calma + batería)
    const coarse = window.matchMedia('(pointer: coarse)').matches;
    let setWidth = 0;
    const measure = () => { setWidth = track.scrollWidth / 3; };
    measure();
    window.addEventListener('load', () => { measure(); viewport.scrollLeft = setWidth; });
    window.addEventListener('resize', measure);
    viewport.scrollLeft = setWidth; // arrancar en la copia del medio

    const wrap = () => {
      if (!setWidth) return;
      if (viewport.scrollLeft >= setWidth * 2) viewport.scrollLeft -= setWidth;
      else if (viewport.scrollLeft <= setWidth * 0.5) viewport.scrollLeft += setWidth;
    };

    let hovering = false, dragging = false, startX = 0, startScroll = 0;
    let lastX = 0, dragVel = 0;      // velocidad del arrastre
    let sway = 0, swayVel = 0;       // ángulo de balanceo (péndulo)
    const speed = 0.6;               // px por frame (~40px/s)
    const clamp = (v, m) => Math.max(-m, Math.min(m, v));

    function tick() {
      if (!reduce && !coarse && !hovering && !dragging) { viewport.scrollLeft += speed; wrap(); }

      // Balanceo: mientras arrastro las tarjetas se inclinan; al soltar, resorte a 0
      if (!reduce) {
        dragVel *= 0.55;
        if (dragging) {
          const target = clamp(-dragVel * 0.4, 9);
          sway += (target - sway) * 0.2;
        } else {
          swayVel += (0 - sway) * 0.11;   // resorte
          swayVel *= 0.8;                  // amortiguación
          sway += swayVel;
          if (Math.abs(sway) < 0.01 && Math.abs(swayVel) < 0.01) sway = 0;
        }
        track.style.setProperty('--sway', sway.toFixed(2) + 'deg');
      }
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);

    viewport.addEventListener('mouseenter', () => { hovering = true; });
    viewport.addEventListener('mouseleave', () => { hovering = false; });

    viewport.addEventListener('pointerdown', (e) => {
      dragging = true; startX = e.clientX; lastX = e.clientX; startScroll = viewport.scrollLeft;
      viewport.classList.add('is-dragging');
      viewport.setPointerCapture(e.pointerId);
    });
    viewport.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      e.preventDefault();
      dragVel = e.clientX - lastX; lastX = e.clientX;
      viewport.scrollLeft = startScroll - (e.clientX - startX);
      wrap();
    });
    const endDrag = () => { dragging = false; viewport.classList.remove('is-dragging'); };
    viewport.addEventListener('pointerup', endDrag);
    viewport.addEventListener('pointercancel', endDrag);

    // rueda del mouse: scroll horizontal también
    viewport.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
        viewport.scrollLeft += e.deltaY; wrap();
      }
    }, { passive: true });
  }
</script>
