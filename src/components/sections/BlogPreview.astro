---
import { getCollection } from 'astro:content';
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);

function formatDate(d: string | Date) {
  return new Date(d).toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
}

function initials(name?: string) {
  return (name || 'Claudio Luna').split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
}
---
<section id="blog" class="py-16 sm:py-24 lg:py-32">
  <div class="container mx-auto px-4 sm:px-6">

    <div class="reveal">
      <div class="flex items-center gap-4 mb-8">
        <span class="w-12 h-px" style="background:hsl(var(--muted-foreground))"></span>
        <span class="text-sm uppercase tracking-widest font-medium">Blog & Comunidad</span>
      </div>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 lg:mb-16">
        <div class="max-w-2xl">
          <h2 class="font-display text-display-md font-bold glow-text mb-4">Lo que aprendo, lo comparto.</h2>
          <p class="text-lg mb-5" style="color:hsl(var(--muted-foreground))">Artículos, flujos de n8n listos para importar, sistemas y repositorios. Todo se publica acá, gratis, para la comunidad.</p>
          <div class="flex flex-wrap gap-2">
            {['✍️ Artículos técnicos','⚙️ Flujos n8n descargables','🧩 Sistemas y repositorios'].map(t => (
              <span class="pill-brutal px-3 py-1.5 text-xs" style="background:hsl(var(--card))">{t}</span>
            ))}
          </div>
        </div>
        <a href="/blog" class="group self-start md:self-auto flex items-center gap-2 text-sm font-medium transition-colors hover:opacity-70" style="color:hsl(var(--muted-foreground))">
          Ver todos los artículos
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {posts.map((post, i) => (
        <article class="card-brutal group flex flex-col overflow-hidden reveal"
                 style={`background:hsl(var(--card));transition-delay:${i*150}ms`}>
          <div class="img-fx aspect-[16/10] relative" style="background:hsl(var(--secondary)/0.5);border-bottom:2px solid hsl(var(--foreground))">
            {post.data.coverImage && (
              <div class="img-parallax-layer" data-parallax>
                <img src={post.data.coverImage} alt={post.data.title}
                     class="img-glitch w-full h-full object-cover" />
              </div>
            )}
            <span class="pill-brutal absolute top-4 left-4 px-3 py-1 text-xs"
                  style="background:hsl(var(--primary));color:hsl(var(--foreground))">
              {post.data.category || post.data.tags?.[0] || 'Blog'}
            </span>
          </div>

          <div class="flex flex-col flex-1 p-5 sm:p-6">
            <div class="flex flex-wrap items-center gap-3 text-xs mb-3" style="color:hsl(var(--muted-foreground))">
              <span>{formatDate(post.data.publishedAt)}</span>
              {post.data.readTime && <span>· {post.data.readTime} min</span>}
            </div>
            <h3 class="font-display text-lg font-semibold mb-3 line-clamp-2 transition-colors group-hover:opacity-70">
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </h3>
            <p class="text-sm mb-4 flex-1 line-clamp-3" style="color:hsl(var(--muted-foreground))">{post.data.excerpt}</p>

            <div class="flex items-center justify-between pt-4 border-t" style="border-color:hsl(var(--border))">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full border-brutal flex items-center justify-center text-xs font-bold"
                     style="background:hsl(var(--primary));color:hsl(var(--foreground))">{initials(post.data.author)}</div>
                <span class="text-xs font-medium">{post.data.author}</span>
              </div>
              <a href={`/blog/${post.slug}`} class="text-xs font-medium flex items-center gap-1 transition-colors hover:opacity-70"
                 style="color:hsl(var(--foreground))">
                Leer más
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
