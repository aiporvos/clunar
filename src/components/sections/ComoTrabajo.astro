---
const steps = [
  {
    n: '01',
    title: 'Conectás tus canales',
    description: 'WhatsApp, tu web, tu email, tu CRM. Donde ya estás, el agente también.',
    tools: ['WhatsApp Business','Web chat','Gmail / Outlook','API REST'],
  },
  {
    n: '02',
    title: 'Entrenamos el agente',
    description: 'Lo alimentamos con la info de tu negocio: productos, precios, políticas, tono. En 48h está listo.',
    tools: ['Tus docs y catálogos','PDFs y manuales','FAQs internas','Historial de chats'],
  },
  {
    n: '03',
    title: 'Trabaja solo 24/7',
    description: 'El agente atiende, vende, cobra o lee documentos. Te avisa solo cuando necesita tu ojo.',
    tools: ['Reportes semanales','Alertas críticas','Dashboard en tiempo real','Escalado a humano'],
  },
];
---
<section id="como-funciona" class="py-24 lg:py-32">
  <div class="container mx-auto px-6">

    <div class="reveal">
      <div class="flex items-center gap-4 mb-8">
        <span class="w-12 h-px" style="background:hsl(var(--foreground))"></span>
        <span class="text-sm uppercase tracking-widest font-medium">Cómo Funciona</span>
      </div>
      <div class="max-w-3xl mb-16">
        <h2 class="font-display text-display-md font-bold glow-text mb-6">Tres pasos. Sin líos.</h2>
        <p class="text-lg" style="color:hsl(var(--muted-foreground))">
          No necesitás saber de IA. Nosotros nos encargamos de todo el setup. Vos solo decís qué querés automatizar.
        </p>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
      {steps.map((s, i) => (
        <div class="card-brutal group flex items-start gap-4 p-6 reveal-x"
             style={`background:hsl(var(--card));transition-delay:${i*100}ms`}>
          <div class="flex-shrink-0 mt-1 w-11 h-11 rounded-lg border-brutal shadow-brutal-sm flex items-center justify-center" style="background:hsl(var(--primary))">
            <span class="font-display font-bold text-lg" style="color:hsl(var(--foreground))">{s.n}</span>
          </div>
          <div>
            <h3 class="font-display font-semibold mb-2 text-lg">{s.title}</h3>
            <p class="text-sm mb-4" style="color:hsl(var(--muted-foreground))">{s.description}</p>
            <div class="flex flex-wrap gap-2">
              {s.tools.map(t => (
                <span class="pill-brutal px-2.5 py-1 text-xs"
                      style="background:hsl(var(--background));color:hsl(var(--foreground))">
                  {t}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="border-brutal shadow-brutal-lg rounded-2xl p-8 lg:p-12 reveal" style="background:hsl(var(--primary))">
      <div class="grid lg:grid-cols-3 gap-8 text-center">
        <div>
          <p class="font-display text-4xl font-bold mb-2" style="color:hsl(var(--foreground))">48h</p>
          <p class="text-sm font-semibold" style="color:hsl(var(--foreground))">Setup completo</p>
        </div>
        <div>
          <p class="font-display text-4xl font-bold mb-2" style="color:hsl(var(--foreground))">$0</p>
          <p class="text-sm font-semibold" style="color:hsl(var(--foreground))">Costo de programación</p>
        </div>
        <div>
          <p class="font-display text-4xl font-bold mb-2" style="color:hsl(var(--foreground))">∞</p>
          <p class="text-sm font-semibold" style="color:hsl(var(--foreground))">Consultas simultáneas</p>
        </div>
      </div>
      <p class="text-center text-lg font-display font-semibold mt-8">
        "Empezás a ver resultados desde la primera semana."
      </p>
    </div>

  </div>
</section>
