---
<section id="inicio" class="min-h-screen flex flex-col justify-center pt-16 bg-[#f5f5f0]">
  <div class="container-site py-20">
    <div class="max-w-4xl">
      <h1 class="font-black uppercase tracking-tight leading-none text-[clamp(4rem,12vw,9rem)] text-[#0a0a0a]">
        MENTORA<br/>
        <span class="bg-[#7c3aed] text-white px-2">COACHING</span><br/>
        LIDERAZGO
      </h1>
      <div class="mt-8 max-w-xl">
        <p class="text-lg text-[#0a0a0a]/70 leading-relaxed">
          Soy Valeria De Giorgi, coach profesional y mentora en desarrollo humano y organizacional.
        </p>
      </div>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="#contacto" class="btn-primary">
          Agendar una conversación
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#servicios" class="btn-secondary">Conocer servicios</a>
      </div>
      <div class="mt-16 flex gap-10">
        <div>
          <p class="font-black text-4xl text-[#0a0a0a]">+100</p>
          <p class="text-sm text-[#0a0a0a]/60 mt-1">Profesionales acompañados</p>
        </div>
        <div>
          <p class="font-black text-4xl text-[#0a0a0a]">15+</p>
          <p class="text-sm text-[#0a0a0a]/60 mt-1">Años de experiencia</p>
        </div>
        <div>
          <p class="font-black text-4xl text-[#0a0a0a]">100%</p>
          <p class="text-sm text-[#0a0a0a]/60 mt-1">Compromiso</p>
        </div>
      </div>
      <div class="mt-16">
        <a href="#quien-soy" class="inline-flex items-center gap-2 text-sm text-[#0a0a0a]/60 hover:text-[#7c3aed] transition-colors">
          Conocer más
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
