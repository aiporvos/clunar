---
const audiences = [
  'Pymes con alto volumen de consultas que no pueden atender en tiempo real.',
  'E-commerce que pierde ventas por carritos abandonados y sin seguimiento.',
  'Estudios jurídicos con montañas de documentos y consultas repetitivas.',
  'Inmobiliarias que quieren calificar leads y agendar visitas sin esfuerzo manual.',
  'Servicios profesionales que invierten horas en tareas administrativas.',
  'Cualquier negocio con tareas repetitivas que le comen tiempo y plata.',
];
---
<section class="py-24 lg:py-32" style="background:hsl(var(--secondary)/0.3)">
  <div class="container mx-auto px-6">

    <div class="flex items-center gap-4 mb-8 reveal">
      <span class="w-12 h-px" style="background:hsl(var(--foreground))"></span>
      <span class="text-sm uppercase tracking-widest font-medium">¿Para Quién?</span>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="reveal">
        <h2 class="font-display text-display-md font-bold mb-6">Para negocios que quieren escalar sin sumar costos fijos</h2>
        <p class="text-lg" style="color:hsl(var(--muted-foreground))">si tenés tareas repetitivas que comen tiempo, AIporvos es para vos.</p>
        <p class="text-sm italic mt-4" style="color:hsl(var(--muted-foreground))">"No necesitás un equipo de tech. Solo contarnos qué querés resolver."</p>
      </div>

      <div class="space-y-4">
        {audiences.map((a, i) => (
          <div class="card-brutal flex items-start gap-4 p-4 reveal"
               style={`background:hsl(var(--card));transition-delay:${i*100}ms`}>
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color:hsl(var(--primary))" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <p>{a}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-20 reveal">
      <h3 class="font-display text-2xl font-bold mb-4">¿Te identificás?</h3>
      <p class="max-w-xl mx-auto mb-8" style="color:hsl(var(--muted-foreground))">
        Si tu negocio tiene tareas que se repiten y te roban tiempo, hay un agente de AIporvos listo para encargarse.
      </p>
      <a href="https://wa.me/542604844952" target="_blank" rel="noopener noreferrer"
         class="btn-brutal group inline-flex items-center gap-2 px-8 py-3 text-sm"
         style="background:hsl(var(--primary));color:hsl(var(--primary-foreground))">
        Hablemos por WhatsApp
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>
