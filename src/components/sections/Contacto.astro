---
---
<section id="contacto" class="py-24 lg:py-32">
  <div class="container mx-auto px-6">

    <div class="flex items-center gap-4 mb-8 reveal">
      <span class="w-12 h-px" style="background:hsl(var(--muted-foreground))"></span>
      <span class="text-sm uppercase tracking-widest font-medium">Contacto</span>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">

      <div class="reveal">
        <h2 class="font-display text-display-md font-bold glow-text mb-6">Contame el proceso que te duele.</h2>
        <p class="text-lg mb-8" style="color:hsl(var(--muted-foreground))">
          Diagnóstico inicial sin costo: revisamos tu proceso, tus sistemas y tus datos, y te digo
          qué conviene automatizar — y qué no. Respuesta en menos de 24 horas.
        </p>

        <!-- WhatsApp CTA -->
        <a href="https://wa.me/542604844952"
           target="_blank"
           rel="noopener noreferrer"
           class="card-brutal group flex items-center gap-3 px-6 py-4 mb-8"
           style="background:hsl(var(--primary));color:hsl(var(--foreground))">
          <svg class="w-6 h-6 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <div>
            <p class="font-semibold">+54 260 484-4952</p>
            <p class="text-sm opacity-70">WhatsApp · API oficial de Meta</p>
          </div>
          <svg class="w-4 h-4 ml-auto transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>

        <div class="card-brutal p-6" style="background:hsl(var(--card))">
          <p class="text-sm mb-2 font-semibold" style="color:hsl(var(--muted-foreground))">El diagnóstico incluye:</p>
          <ul class="space-y-2">
            {['Relevamiento de tu proceso y sistemas','Mapa de datos: qué información entra en juego y cómo se protege','Propuesta de arquitectura con costos reales','Sin compromiso — si no conviene automatizar, te lo digo'].map(item => (
              <li class="flex items-center gap-2 text-sm font-medium">
                <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background:hsl(var(--primary))"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <form id="contact-form" class="space-y-6 reveal">
        <div>
          <input type="text" name="nombre" placeholder="Tu nombre" required
                 class="w-full h-14 px-4 text-base rounded-lg border-brutal outline-none"
                 style="background:hsl(var(--card));color:hsl(var(--foreground))" />
        </div>
        <div>
          <input type="email" name="email" placeholder="Tu email" required
                 class="w-full h-14 px-4 text-base rounded-lg border-brutal outline-none"
                 style="background:hsl(var(--card));color:hsl(var(--foreground))" />
        </div>
        <div>
          <select name="flujo"
                  class="w-full h-14 px-4 text-base rounded-lg border-brutal outline-none"
                  style="background:hsl(var(--card));color:hsl(var(--foreground))">
            <option value="">¿Qué necesitás resolver?</option>
            <option>Sistema multi-agente (atención, ventas, procesos)</option>
            <option>RAG — conocimiento propio consultable</option>
            <option>Integración de sistemas (ERP, CRM, facturación)</option>
            <option>Seguridad y gobernanza de datos</option>
            <option>Consultoría — diagnóstico y roadmap de IA</option>
            <option>Formación de equipos</option>
            <option>No estoy seguro, necesito orientación</option>
          </select>
        </div>
        <div>
          <textarea name="mensaje" rows="4" placeholder="Contame sobre tu proceso y tus sistemas (opcional)"
                    class="w-full px-4 py-3 text-base rounded-lg border-brutal outline-none resize-none"
                    style="background:hsl(var(--card));color:hsl(var(--foreground))"></textarea>
        </div>
        <button type="submit" class="btn-brutal btn-shine group w-full flex items-center justify-center gap-2 py-4 text-sm"
                style="background:hsl(var(--primary));color:hsl(var(--primary-foreground))">
          Pedir diagnóstico sin costo
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </button>
        <p class="text-xs text-center" style="color:hsl(var(--muted-foreground))">Sin spam. Respuesta en menos de 24 horas.</p>
      </form>

    </div>
  </div>
</section>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector('button[type="submit"]');
    if (btn) btn.textContent = 'Enviado — te respondo en menos de 24 h';
    setTimeout(() => (e.target as HTMLFormElement).reset(), 3000);
  });
</script>
