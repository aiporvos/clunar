---
---
<section id="contacto" class="py-24 bg-[#f5f5f0]">
  <div class="container-site">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div>
        <p class="section-label">Contacto</p>
        <h2 class="text-3xl md:text-4xl font-bold text-[#0a0a0a] mb-4">Comencemos una conversación</h2>
        <p class="text-[#0a0a0a]/60 leading-relaxed mb-8">Completá el formulario o escribime directamente. Respondo en menos de 24 horas.</p>
        <div class="flex gap-4 mb-8">
          <a href="#" aria-label="LinkedIn" class="w-10 h-10 rounded-full bg-white border border-[#e5e5e0] flex items-center justify-center hover:border-[#7c3aed] hover:text-[#7c3aed] transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" aria-label="Instagram" class="w-10 h-10 rounded-full bg-white border border-[#e5e5e0] flex items-center justify-center hover:border-[#7c3aed] hover:text-[#7c3aed] transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="mailto:contacto@vdgmentorias.com" aria-label="Email" class="w-10 h-10 rounded-full bg-white border border-[#e5e5e0] flex items-center justify-center hover:border-[#7c3aed] hover:text-[#7c3aed] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
        </div>
        <div class="text-sm text-[#0a0a0a]/50">
          <p class="font-medium text-[#0a0a0a]/70 mb-1">Disponible para:</p>
          <p>Mentorías / Coaching / Consultoría</p>
        </div>
      </div>
      <form class="card flex flex-col gap-4">
        <div>
          <label for="nombre" class="block text-sm font-medium text-[#0a0a0a] mb-1.5">Tu nombre</label>
          <input id="nombre" type="text" name="nombre" placeholder="Tu nombre" class="w-full border border-[#e5e5e0] rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#7c3aed] bg-[#f5f5f0] transition-colors"/>
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-[#0a0a0a] mb-1.5">Tu email</label>
          <input id="email" type="email" name="email" placeholder="tu@email.com" class="w-full border border-[#e5e5e0] rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#7c3aed] bg-[#f5f5f0] transition-colors"/>
        </div>
        <div>
          <label for="mensaje" class="block text-sm font-medium text-[#0a0a0a] mb-1.5">¿En qué puedo ayudarte?</label>
          <textarea id="mensaje" name="mensaje" rows="4" placeholder="Contame brevemente en qué puedo acompañarte..." class="w-full border border-[#e5e5e0] rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#7c3aed] bg-[#f5f5f0] transition-colors resize-none"></textarea>
        </div>
        <button type="submit" class="btn-primary justify-center">
          Enviar mensaje
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </button>
      </form>
    </div>
  </div>
</section>
