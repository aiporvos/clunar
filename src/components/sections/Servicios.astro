---
const services = [
  {
    title: 'Coaching de Liderazgo',
    description: 'Para líderes y mandos medios que quieren ejercer su rol con más consciencia, criterio y capacidad de impacto real.',
    features: ['Autoconocimiento en el ejercicio del rol','Toma de decisiones en contextos complejos','Comunicación y gestión de equipos','Liderazgo consciente y efectivo'],
    quote: 'No hay cambio verdadero si no se camina distinto.',
    cta: 'Consultar',
    ctaHref: '#contacto',
  },
  {
    title: 'Formaciones para organizaciones',
    description: 'Programas de desarrollo para equipos, mandos medios y directivos. Diseñados según el contexto, los objetivos y las personas involucradas.',
    features: ['Liderazgo estratégico y situacional','Liderazgo en IA — equipos en la era digital','Comunicación, clima y cultura organizacional','Programas a medida para sectores específicos'],
    quote: 'El desarrollo organizacional comienza en la forma de trabajar juntos.',
    cta: 'Ver formaciones',
    ctaHref: '#contacto',
  },
  {
    title: 'Consultoría en desarrollo organizacional',
    description: 'Para organizaciones que quieren mejorar su cultura, clima y liderazgo desde adentro. Trabajo con equipos directivos y áreas de RRHH.',
    features: ['Diagnóstico de cultura y clima laboral','Desarrollo de liderazgo en mandos medios','Gestión y desarrollo del talento','Fortalecimiento de equipos directivos'],
    quote: 'Intervengo donde es necesario ordenar, pensar y potenciar el trabajo.',
    cta: 'Hablemos',
    ctaHref: '#contacto',
  },
];
---
<section id="servicios" class="py-24 lg:py-32" style="background:hsl(var(--secondary)/0.3)">
  <div class="container mx-auto px-6">

    <div class="reveal">
      <div class="flex items-center gap-4 mb-8">
        <span class="w-12 h-px" style="background:hsl(var(--foreground))"></span>
        <span class="text-sm uppercase tracking-widest font-medium">Servicios</span>
      </div>
      <div class="max-w-2xl mb-16">
        <h2 class="font-display text-display-md font-bold mb-6">Tres formas de trabajar juntos.</h2>
        <p class="text-lg" style="color:hsl(var(--muted-foreground))">Según dónde estés y qué necesite tu organización, hay un punto de entrada. Todos los procesos se diseñan con criterio, sin recetas universales.</p>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      {services.map((s, i) => (
        <div class="group flex flex-col p-8 rounded-lg border transition-all duration-500 hover:shadow-lg reveal"
             style={`background:hsl(var(--background));border-color:hsl(var(--border));transition-delay:${i*150}ms`}>

          <div class="flex items-start justify-between mb-6">
            <div class="w-10 h-10 rounded-full border flex items-center justify-center" style="border-color:hsl(var(--border))">
              <span class="font-display font-bold text-sm">{i+1}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full animate-pulse" style="background:hsl(var(--success))"></span>
              <span class="text-xs font-medium uppercase tracking-wide" style="color:hsl(var(--success))">Disponible</span>
            </div>
          </div>

          <h3 class="font-display text-xl font-bold mb-3">{s.title}</h3>
          <p class="mb-6 leading-relaxed" style="color:hsl(var(--muted-foreground))">{s.description}</p>

          <ul class="space-y-3 mb-6 flex-1">
            {s.features.map(f => (
              <li class="flex items-start gap-3 text-sm" style="color:hsl(var(--muted-foreground))">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color:hsl(var(--accent))" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>

          <p class="text-sm italic border-t pt-4 mb-6" style="color:hsl(var(--muted-foreground));border-color:hsl(var(--border))">
            "{s.quote}"
          </p>

          <a href={s.ctaHref} class="group/btn flex items-center justify-center gap-2 w-full py-3 rounded-md text-sm font-medium uppercase tracking-wide transition-all"
             style="background:hsl(var(--foreground));color:hsl(var(--background))">
            {s.cta}
            <svg class="w-4 h-4 transition-transform group-hover/btn:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
